VITE_API_BASE_URL=/api/v1

# --- Live mandate tracking (all optional; leave empty for pure demo mode) ---
# Pooled Postgres connection string (Neon/Supabase pgbouncer endpoint).
# Empty = in-memory fallback store, `npm run dev:all` works with zero setup.
DATABASE_URL=
# Server-only — powers counterpart finding narratives. No VITE_ prefix, so it
# can never leak into the browser bundle. Empty = deterministic template copy.
ANTHROPIC_API_KEY=
# Shared secret Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>` to
# GET /api/v1/agent-sweep. Empty locally (the dev server sweeps on an interval).
CRON_SECRET=
# Pause between mandates so the live analysis strip on Findings is watchable
# rather than a flash. Default 900ms; never applied to cron-triggered sweeps.
# Set to 0 to make sweeps run flat out.
REWIVE_SWEEP_PACE_MS=
